{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "src",
  "testRegex": ".spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": ["/node_modules/(?!jose|firebase-admin|jwks-rsa)/"],
  "coverageDirectory": "../coverage",
  "testEnvironment": "node"
}
